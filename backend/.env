# ── Required ──────────────────────────────────────────────────────────────────
# Add your Anthropic API key below (get it from https://console.anthropic.com)
ANTHROPIC_API_KEY=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

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/jobs.db

# ── Output directory (where agents write generated project files) ─────────────
OUTPUT_DIR=./output

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_EXPIRE_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_SESSIONS_PER_USER=2
API_SEMAPHORE_LIMIT=3

# ── Debug ────────────────────────────────────────────────────────────────────
DEBUG=true
