# DEVOPS_AGENT | 2026-05-10 | Environment variable reference - copy to .env and fill in values

# ============================================================
# REQUIRED
# ============================================================

# Your Anthropic API key (get it at https://console.anthropic.com)
ANTHROPIC_API_KEY=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
# ============================================================
# DATABASE
# ============================================================

# PostgreSQL (for production / docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/orchestrator

# SQLite (for local dev without Docker - uncomment to use)
# DATABASE_URL=sqlite+aiosqlite:///./data/dev.db

# ============================================================
# FILE OUTPUT
# ============================================================

# Directory where generated project files are written
OUTPUT_DIR=./output

# ============================================================
# JWT AUTHENTICATION (RS256)
# ============================================================
# Generate keys with: python -m scripts.generate_keys
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_EXPIRE_MINUTES=1440

# ============================================================
# CORS
# ============================================================
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================
# RATE LIMITING & CONCURRENCY
# ============================================================
MAX_SESSIONS_PER_USER=2
API_SEMAPHORE_LIMIT=3

# ============================================================
# POSTGRESQL (docker-compose)
# ============================================================
POSTGRES_DB=orchestrator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_a_strong_password_in_production

# ============================================================
# OPTIONAL
# ============================================================
DEBUG=false
